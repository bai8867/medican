          <mxGeometry x="0" y="120" width="1920" height="6" as="geometry" />
        </mxCell>
        <mxCell id="p8_title" value="  02. 国内外研究现状" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;" parent="1" vertex="1">
