    <mxGraphModel dx="1434" dy="836" grid="0" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p9_bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F7F8FA;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="0" y="0" width="1920" height="1080" as="geometry" />
        </mxCell>
        <mxCell id="p9_topbar" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0170C1;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="0" y="0" width="1920" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p9_line" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="0" y="120" width="1920" height="6" as="geometry" />
        </mxCell>
        <mxCell id="p9_title" value="  02. 国内外研究现状" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#FFFFFF;fontFamily=微软雅黑;" parent="1" vertex="1">
          <mxGeometry x="0" y="0" width="1920" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p9_botline" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="0" y="1040" width="1920" height="4" as="geometry" />
        </mxCell>
        <mxCell id="p9_date" value="2026 年 3 月" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;fontSize=14;fontColor=#4A5568;fontFamily=微软雅黑;" parent="1" vertex="1">
          <mxGeometry x="1400" y="1044" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p9_nPFz46_badge" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="100" y="170" width="10" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p9_PDjqip_t" value="现有方法局限性（本文切入点）" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;" parent="1" vertex="1">
          <mxGeometry x="120" y="170" width="1700" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p9_VJIqVL_b" value="• 传统方法依赖规则或精确模型，面对高度动态场景性能下降&#xa;• 单传感器依赖导致感知不完整，易受遮挡/噪声影响&#xa;• 深度学习方法对数据依赖强，跨场景泛化不足&#xa;• 端到端系统缺少工程化验证与可复现实验对比" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontColor=#1A1A2E;fontFamily=微软雅黑;" parent="1" vertex="1">
          <mxGeometry x="120" y="220" width="1680" height="320" as="geometry" />
        </mxCell>
        <mxCell id="p9_B5Lzxo_badge" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#C9A84C;strokeColor=none;" parent="1" vertex="1">
          <mxGeometry x="100" y="590" width="10" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p9_iGFfWd_t" value="本文工作定位" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;" parent="1" vertex="1">
          <mxGeometry x="120" y="590" width="1700" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p9_3hjOkY_b" value="• 以 DDPG 为基准，提出 DRL 路径规划优化方案（D-RL-Path）&#xa;• 以 CNN+RNN 为融合骨干，提出多传感器融合路径规划网络（Fusion-Path）&#xa;• 构建 CARLA 仿真数据集，定义评价指标并开展对比/消融实验&#xa;• 实现系统原型，支撑实验复现与演示验证" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontColor=#1A1A2E;fontFamily=微软雅黑;" parent="1" vertex="1">
          <mxGeometry x="120" y="640" width="1680" height="330" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
