        <mxCell id="p13_aMuFbh_t" value="关键设计要点" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#1A1A2E;fontFamily=微软雅黑;" parent="1" vertex="1">
